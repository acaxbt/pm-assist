# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="PRD Chat"
NEXTAUTH_URL="http://localhost:3000"
# generate: openssl rand -base64 32
AUTH_SECRET=""

# ─────────────────────────────────────────────
# Auth — Google OAuth
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# ─────────────────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Restrict login ke domain ini (comma-separated jika lebih dari 1)
ALLOWED_EMAIL_DOMAINS="detik.com"

# ─────────────────────────────────────────────
# Database — Neon Postgres
# https://console.neon.tech
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (non-pooled) URL utk Prisma migrate.
# Untuk Neon pooled URL (hostname mengandung "-pooler"), ini wajib diisi.
# Untuk database biasa/non-pooled, build script akan fallback ke DATABASE_URL bila kosong.
DIRECT_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─────────────────────────────────────────────
# LLM — OpenRouter
# https://openrouter.ai/keys
# ─────────────────────────────────────────────
OPENROUTER_API_KEY=""
# default model utk drafting (cepat & murah)
OPENROUTER_MODEL_DEFAULT="openai/gpt-4o-mini"
# model utk final polish / critique (lebih bagus reasoning)
OPENROUTER_MODEL_PREMIUM="anthropic/claude-sonnet-4.5"
# (opsional) untuk OpenRouter ranking/headers
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_SITE_NAME="PRD Chat (acagc)"

# ─────────────────────────────────────────────
# File Storage — Vercel Blob
# https://vercel.com/dashboard/stores
# ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ─────────────────────────────────────────────
# Plane.so integration
# Cloud: https://app.plane.so  |  Self-hosted: https://plane.yourcompany.com
# PAT: Workspace Settings → API Tokens
# ─────────────────────────────────────────────
PLANE_BASE_URL="https://api.plane.so"
PLANE_WORKSPACE_SLUG=""
PLANE_API_TOKEN=""
